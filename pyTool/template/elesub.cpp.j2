#include "{{ele.name}}.h"
#include "{{femDataClassName}}.h"
#include "{{field.fieldDataClassName}}.h"
{#### Constructor function ####}
{{ele.name}}::{{ele.name}}(CDFEG::PhyFieldData* pData)
    : CDFEG::{{baseClass}}({{baseClassParam}}) {
    _name="{{ele.name}}";
    _dispNames = { {% for name in ele.dispNames %}"{{name}}"{% if not loop.last %}, {% endif %}{% endfor %} };
    _paramNames ={ {% for name in ele.paramNames %}"{{name}}"{% if not loop.last %}, {% endif %}{% endfor %} };
    _types.insert("{{ele.name}}");
{{ele.initCode}}
{% if baseClass == "IsoEleBase" %}
{% set nGaus = ele.gaussPoints|length %}
{% set nDisp = ele.dispNames|length %}
{% set nVar = ele.nNodes * nDisp %}
    _dim = {{ ele.dim }};
    _nGaus = {{ nGaus }};
    _nDisp = {{ nDisp }};
    _nRefc = {{ ele.dim }};
    _nCoor = {{ dim }};
    _nVar = {{ nVar }};
    _nNode = {{ ele.nNodes }};
    _gaus.resize({{ nGaus }});
    _refc.resize({{ nGaus * ele.dim }});
{% for i in range(nGaus) %}
    _gaus[{{ i }}] = {{ ele.gaussWeights[i] }};
{% for j in range(ele.dim) %}
    _refc[{{ i * ele.dim + j }}] = {{ ele.gaussPoints[i][j] }};
{% endfor %}
{% endfor %}
    caculateShapeCoef({{ dim }});
    _result.emass.resize(_nVar);
    _result.eload.resize(_nVar);
    _result.estif.resize(_nVar * _nVar);
    _result.edamp.resize(_nVar * _nVar);
{% endif %}
{% if ele.vtkCellType %}
    _vtkCellType =VTKCellType::VTK_{{ele.vtkCellType}};
{% else %}
    // TODO: 设置 VTK 单元类型
    // _vtkCellType = VTK_<TYPE>;
{% endif %}
}
{#### Destructor function ####}
{{ele.name}}::~{{ele.name}}() {

}
{#### Main function ####}
CDFEG::EleSubResult& {{ele.name}}::run(
    const std::vector<double>& r,
    const std::map<std::string, std::vector<double>>& coef,
    const std::map<std::string, double>& matParams
) {

{{ele.runCode}}

    if (_bSaveResult) _results.push_back(_result);
    return _result;
}
{#### PostProcessing function ####}
CDFEG::uResult {{ele.name}}::uEle(
    const std::vector<double>& r,
    const std::map<std::string, std::vector<double>>& coef,
    const std::map<std::string, double>& matParams
) {
    CDFEG::uResult  res;

{{ele.uCode}}

    return res;
}
{% if baseClass == "IsoEleBase" %}

std::vector<double> {{ele.name}}::shapeFun(
    const std::vector<double>& refc
) {
    std::vector<double> shapes;
{% if ele.shapeFuns is defined and ele.shapeFuns|length > 0 %}
    double fval;
{% for i in range(dim) %}
    double {{project.coordVars[i]}} = refc[{{i}}];
{% endfor %}
{% for sf in shapeFuns %}
    fval = {{sf}};
    shapes.push_back(fval);
{% endfor %}
{% elif ele.shapeFunCode is defined and ele.shapeFunCode|length > 0 %}
    {{ele.shapeFunCode}}
{% endif %}
    return shapes;
}

{% endif %}
